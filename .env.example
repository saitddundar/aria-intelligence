SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Optional: CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# Optional: Qdrant
QDRANT_RETRY_COUNT=2
QDRANT_RETRY_BACKOFF=0.5
QDRANT_RETRY_MAX_BACKOFF=4.0
QDRANT_RETRY_JITTER=0.2

# Optional: Spotify retry/backoff
SPOTIFY_RETRY_COUNT=3
SPOTIFY_RETRY_BACKOFF=0.5
SPOTIFY_RETRY_MAX_BACKOFF=4.0
SPOTIFY_RETRY_JITTER=0.2

# Optional: RAG
RAG_SCORE_THRESHOLD=0.2
RAG_ENABLE_RERANKER=true
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_MAX_TRACKS_PER_ARTIST=2

# Optional: LLM
LLM_REPROMPT_ON_FAIL=true
LLM_REPROMPT_MAX_RETRIES=1
QWEN_MODEL_PATH=Qwen/Qwen2.5-1.5B-Instruct-GGUF
QWEN_MODEL_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf
QWEN_GPU_LAYERS=-1
